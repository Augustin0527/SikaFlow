# Clés FedaPay — copier ce fichier en .env et remplir les vraies valeurs
# NE PAS COMMITTER le fichier .env dans Git

# Environnement : 'live' ou 'sandbox'
FEDAPAY_ENV=sandbox

# Clés SANDBOX (tests)
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxx
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxx

# Clés LIVE (production) — seulement pour les builds de production
# FEDAPAY_PUBLIC_KEY=pk_live_xxxxxxxxxxxxx
# FEDAPAY_SECRET_KEY=sk_live_xxxxxxxxxxxxx

# Commande de lancement en développement :
# flutter run \
#   --dart-define=FEDAPAY_ENV=sandbox \
#   --dart-define=FEDAPAY_PUBLIC_KEY=pk_sandbox_xxx \
#   --dart-define=FEDAPAY_SECRET_KEY=sk_sandbox_xxx

# Commande de build production :
# flutter build apk \
#   --dart-define=FEDAPAY_ENV=live \
#   --dart-define=FEDAPAY_PUBLIC_KEY=pk_live_xxx \
#   --dart-define=FEDAPAY_SECRET_KEY=sk_live_xxx
