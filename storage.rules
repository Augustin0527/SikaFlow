rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Photos des témoignages — écriture : super_admin uniquement (via l'admin)
    // Lecture publique pour affichage sur la landing page
    match /temoignages/{fileName} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tout le reste est bloqué par défaut
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
